# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True

# Database (optional for local SQLite when unset)
# DATABASE_URL=postgres://...

# Blog images — AWS S3
USE_AWS=True
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=vacation-blog-user
AWS_S3_REGION_NAME=ap-south-1
# Optional path prefix inside bucket (leave empty for bucket root)
# AWS_LOCATION=
# Optional CloudFront or custom domain
# AWS_S3_CUSTOM_DOMAIN=your-cdn.example.com

# Public website URL (sitemap, canonical)
SITE_BASE_URL=https://www.pestcontrol99.com
# API origin for media URLs in CRM (no /api suffix)
PUBLIC_API_BASE_URL=https://api.vacationbna.site
# S3 object ACL for blog uploads (must be readable in browser)
AWS_DEFAULT_ACL=public-read
