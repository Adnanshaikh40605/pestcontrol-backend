# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True

# CRM JWT (SimpleJWT) — use these exact names on Railway/Vercel
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=60

# Database (production)
# DATABASE_URL=postgres://...

# ── AWS S3 media (required on Railway production) ─────────────────────────────
# Turn on either USE_AWS=True OR MEDIA_BACKEND=s3
USE_AWS=True
MEDIA_BACKEND=s3

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# Aliases (optional — same values as above)
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=ap-south-1

# Image processing
IMAGE_MAX_MB=10
IMAGE_WEBP_QUALITY=82
IMAGE_MAX_WIDTH=1920
BLOG_EDITOR_WEBP_QUALITY=80

# S3 objects must be readable in browser (CRM + website)
# Leave empty when bucket uses "Bucket owner enforced" (ACLs disabled). Use bucket policy for public blog images.
AWS_DEFAULT_ACL=

# Optional path prefix inside bucket (usually leave empty)
# AWS_LOCATION=
# Optional CloudFront / custom domain
# AWS_S3_CUSTOM_DOMAIN=cdn.pestcontrol99.com

# Public URLs
SITE_BASE_URL=https://www.pestcontrol99.com
PUBLIC_API_BASE_URL=https://api.vacationbna.site

# Partner app FCM (Firebase Admin — backend only, never commit the JSON key file)
PARTNER_FIREBASE_PROJECT_ID=pest-99-partner-app
# Option A (Railway): paste full service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option B (local): path to downloaded key file (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=pest-99-partner-app-firebase-adminsdk-xxxx.json
